# TraceBullet live sandbox configuration
#
# Copy these names into your shell or local env manager. Do not commit real tokens.

# Coral query runner. The CLI defaults to this Node runner when --source coral is used.
TRACEBULLET_CORAL_QUERY_COMMAND=node
TRACEBULLET_CORAL_QUERY_ARGS=scripts/run-coral-sql.mjs
TRACEBULLET_CORAL_QUERY_RETRIES=1
TRACEBULLET_CORAL_RETRY_DELAY_MS=1000

# Sandbox source scope. Keep these pointed at demo/sandbox sources only.
TRACEBULLET_GITHUB_OWNER=sivaratrisrinivas
TRACEBULLET_GITHUB_REPO=traceBullet
TRACEBULLET_SLACK_CHANNEL_ID=C0B689JN3L6

# Optional helper script only. Required only when posting a fresh Slack marker.
# SLACK_BOT_TOKEN=xoxb-...
