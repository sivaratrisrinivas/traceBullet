# TraceBullet live sandbox configuration
#
# Copy these names into your shell or local env manager. Do not commit real tokens.

# Coral query runner. The CLI defaults to this Node runner when --source coral is used.
TRACEBULLET_CORAL_QUERY_COMMAND=node
TRACEBULLET_CORAL_QUERY_ARGS=scripts/run-coral-sql.mjs
TRACEBULLET_CORAL_QUERY_RETRIES=1
TRACEBULLET_CORAL_RETRY_DELAY_MS=1000

# Optional Operational Enrichment. When enabled, TraceBullet attempts live Coral
# enrichment queries using the templates below, then falls back to labeled demo
# enrichment if optional source queries are not configured or unavailable.
TRACEBULLET_ENABLE_LIVE_ENRICHMENTS=false
# Query templates must return normalized rows:
# Datadog: recordSet, service, metric, observedAt, value, unit, summary
# PagerDuty: recordSet, incidentId, title, status, urgency, triggeredAt, summary
# Available placeholders:
# {{SERVICE_TAG}}, {{SENTRY_ISSUE_ID}}, {{FIRST_SEEN_AT}}, {{PR_NUMBER}}, {{MERGE_COMMIT}}
# TRACEBULLET_DATADOG_ENRICHMENT_QUERY=SELECT 'datadogSignals' AS recordSet, ...
# TRACEBULLET_PAGERDUTY_ENRICHMENT_QUERY=SELECT 'pagerDutyIncidents' AS recordSet, ...

# Optional LLM Narrative. Use Gemini for cloud narrative summaries.
TRACEBULLET_NARRATIVE_PROVIDER=gemini
TRACEBULLET_GEMINI_MODEL=gemini-3.5-flash
TRACEBULLET_GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=your_key_here
#
# Or use local Ollama. Install Ollama locally and pull the default model:
# ollama pull qwen3:0.6b
TRACEBULLET_OLLAMA_URL=http://localhost:11434
TRACEBULLET_OLLAMA_MODEL=qwen3:0.6b
# Set to deterministic to skip LLM calls and use the template narrative.
# TRACEBULLET_NARRATIVE_MODE=deterministic

# Sandbox source scope. Keep these pointed at demo/sandbox sources only.
TRACEBULLET_GITHUB_OWNER=sivaratrisrinivas
TRACEBULLET_GITHUB_REPO=traceBullet
TRACEBULLET_SLACK_CHANNEL_ID=C0B689JN3L6

# Optional helper script only. Required only when posting a fresh Slack marker.
# SLACK_BOT_TOKEN=xoxb-...
